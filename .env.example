# ── Telegram ───────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
ADMIN_TELEGRAM_ID=123456789
ADMIN_NAME_ALIASES=Иван Иванович,Иванов И.И.,@ivanov_boss

# 7 group chat IDs, comma-separated
MONITORED_CHAT_IDS=-1001111111111,-1002222222222,-1003333333333,-1004444444444,-1005555555555,-1006666666666,-1007777777777

# ── AI API ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
WHISPER_ENABLED=true
DAILY_AI_BUDGET_USD=5.00

# ── Database ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rgo_bot:rgo_bot_password@localhost:5432/rgo_bot

# ── Schedule ───────────────────────────────────────
TIMEZONE=Asia/Yekaterinburg
WORK_DAYS=1,2,3,4,5
DAILY_REPORT_TIME=19:00
MORNING_REC_TIME=08:30
TASK_CLASSIFIER_INTERVAL_MIN=60

# ── Thresholds ─────────────────────────────────────
TASK_CONFIDENCE_THRESHOLD=0.70
SILENCE_ALERT_HOURS=3
SILENCE_WORK_START=09
SILENCE_WORK_END=19
MASS_FORWARD_THRESHOLD=5
SELF_CONTROL_LOW_THRESHOLD=0.40

# ── Web (Mini App) ─────────────────────────────────
WEB_PORT=8080
WEBAPP_URL=https://your-domain.ru

# ── Logging ────────────────────────────────────────
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
